---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Harmattan — Ghana Air Quality Monitor",
  description = "Real-time air quality monitoring for Ghana. Track pollution levels, get health advisories, and report environmental hazards in your community.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0f1115" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <link
      rel="stylesheet"
      href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
      crossorigin=""
    />
  </head>
  <body class="font-sans antialiased">
    <nav class="border-b border-surface-700 bg-surface-800/80 backdrop-blur-sm sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 text-harmattan-400 font-bold text-xl tracking-tight">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none" class="text-harmattan-500">
            <circle cx="14" cy="14" r="12" stroke="currentColor" stroke-width="2" />
            <path d="M8 14c0-3.3 2.7-6 6-6s6 2.7 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
            <circle cx="14" cy="14" r="2" fill="currentColor" />
          </svg>
          Harmattan
        </a>
        <div class="flex items-center gap-6 text-sm">
          <a href="/" class="text-gray-300 hover:text-harmattan-400 transition-colors">Dashboard</a>
          <a href="/about" class="text-gray-300 hover:text-harmattan-400 transition-colors">About</a>
          <a href="/report" class="bg-harmattan-600 hover:bg-harmattan-500 text-white px-3 py-1.5 rounded-lg text-sm font-medium transition-colors">
            Report Pollution
          </a>
        </div>
      </div>
    </nav>
    <slot />
    <footer class="border-t border-surface-700 bg-surface-800/50 mt-16">
      <div class="max-w-7xl mx-auto px-4 py-8 text-center text-sm text-gray-500">
        <p>Harmattan &mdash; Open-source air quality monitoring for Ghana</p>
        <p class="mt-1">Tech Hub Africa Hackathon 2026 &middot; Pollution Control Track</p>
      </div>
    </footer>
  </body>
</html>
