---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Report Pollution — Harmattan">
  <main class="max-w-2xl mx-auto px-4 py-12">
    <a href="/" class="text-harmattan-400 hover:text-harmattan-300 text-sm mb-6 inline-block">
      &larr; Back to Dashboard
    </a>

    <h1 class="text-3xl font-bold text-gray-100 tracking-tight mb-2">
      Report a Pollution Event
    </h1>
    <p class="text-gray-400 mb-8">
      Help improve air quality data in your community. Your reports contribute to a
      more accurate picture of pollution across Ghana.
    </p>

    <form id="report-form" class="space-y-6">
      <div>
        <label for="location" class="block text-sm font-medium text-gray-300 mb-1">
          Location
        </label>
        <select
          id="location"
          name="location"
          required
          class="w-full rounded-lg bg-surface-800 border border-surface-600 text-gray-200 px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-harmattan-500"
        >
          <option value="">Select a city</option>
          <option value="accra">Accra</option>
          <option value="kumasi">Kumasi</option>
          <option value="tema">Tema</option>
          <option value="takoradi">Takoradi</option>
          <option value="tamale">Tamale</option>
          <option value="cape-coast">Cape Coast</option>
        </select>
      </div>

      <div>
        <label for="type" class="block text-sm font-medium text-gray-300 mb-1">
          Pollution Type
        </label>
        <select
          id="type"
          name="type"
          required
          class="w-full rounded-lg bg-surface-800 border border-surface-600 text-gray-200 px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-harmattan-500"
        >
          <option value="">Select type</option>
          <option value="smoke">Smoke / Burning</option>
          <option value="dust">Dust / Harmattan Haze</option>
          <option value="industrial">Industrial Emissions</option>
          <option value="vehicle">Vehicle Exhaust</option>
          <option value="waste">Waste Burning</option>
          <option value="other">Other</option>
        </select>
      </div>

      <div>
        <label for="severity" class="block text-sm font-medium text-gray-300 mb-1">
          Severity (1 = mild, 5 = severe)
        </label>
        <div class="flex gap-3 mt-1">
          {[1, 2, 3, 4, 5].map((n) => (
            <label class="flex items-center gap-1.5 cursor-pointer">
              <input
                type="radio"
                name="severity"
                value={n}
                required
                class="accent-harmattan-500"
              />
              <span class="text-gray-300 text-sm">{n}</span>
            </label>
          ))}
        </div>
      </div>

      <div>
        <label for="description" class="block text-sm font-medium text-gray-300 mb-1">
          Description
        </label>
        <textarea
          id="description"
          name="description"
          rows="4"
          placeholder="Describe what you observed — smell, visibility, duration..."
          class="w-full rounded-lg bg-surface-800 border border-surface-600 text-gray-200 px-4 py-2.5 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-harmattan-500 resize-none"
        ></textarea>
      </div>

      <button
        type="submit"
        class="w-full bg-harmattan-600 hover:bg-harmattan-500 text-white font-semibold py-3 rounded-lg transition-colors"
      >
        Submit Report
      </button>
    </form>

    <div id="success-msg" class="hidden mt-6 bg-green-900/30 border border-green-700 rounded-lg p-4 text-green-300 text-sm">
      Thank you! Your report has been submitted and will help improve pollution monitoring in your area.
    </div>
  </main>

  <script>
    const form = document.getElementById("report-form") as HTMLFormElement;
    const success = document.getElementById("success-msg")!;

    form.addEventListener("submit", (e) => {
      e.preventDefault();
      const data = new FormData(form);
      const report = Object.fromEntries(data.entries());
      report.timestamp = new Date().toISOString();

      // Store locally (D1 integration for production)
      const reports = JSON.parse(localStorage.getItem("harmattan-reports") || "[]");
      reports.push(report);
      localStorage.setItem("harmattan-reports", JSON.stringify(reports));

      form.reset();
      success.classList.remove("hidden");
      setTimeout(() => success.classList.add("hidden"), 5000);
    });
  </script>
</Layout>
